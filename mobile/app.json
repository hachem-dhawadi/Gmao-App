{
  "expo": {
    "name": "GMAO",
    "slug": "gmao-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "softwareKeyboardLayoutMode": "pan",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "gmao",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      "expo-status-bar",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow GMAO to use the camera to scan asset QR codes and barcodes."
        }
      ]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gmao.mobile"
    },
    "android": {
      "package": "com.gmao.mobile",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#2a85ff",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b44c58dd-a71d-4b49-a160-3c87dfe74b08"
      }
    }
  }
}
